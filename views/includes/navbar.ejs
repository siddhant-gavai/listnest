<nav class="sticky top-0 z-50 bg-white border-b border-gray-200 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      
      <!-- Logo -->
      <a class="flex items-center gap-2 no-underline" href="/listings">
        <i class="fa-solid fa-compass text-indigo-600 text-3xl"></i>
        <span class="text-indigo-600 font-bold text-xl hidden sm:block tracking-tight">Listnest</span>
      </a>

      <!-- Search Bar -->
      <% if (showSearchBar) { %>
      <div class="flex-1 max-w-2xl px-4 hidden md:block">
        <form action="/listings" method="GET" class="flex items-center border border-gray-300 rounded-full shadow-sm hover:shadow-md transition-shadow duration-200 pl-4 py-1.5 focus-within:ring-2 focus-within:ring-indigo-500 focus-within:border-transparent">
          <input 
            type="text" 
            name="q"
            placeholder="Search destinations or titles..." 
            class="flex-grow bg-transparent border-none text-sm outline-none px-2 w-full text-gray-700" 
          />
          <button type="submit" class="bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 hover:scale-105 transform text-white rounded-full p-2.5 ml-2 transition-all duration-200 w-10 h-10 flex items-center justify-center me-1 shadow-md">
            <i class="fa fa-search text-sm"></i>
          </button>
        </form>
      </div>
      <% } %>

      <!-- User Actions -->
      <div class="flex items-center gap-4">
        <a class="text-sm font-semibold text-gray-700 hover:bg-gray-100 px-4 py-2 rounded-full transition-colors hidden sm:block no-underline" href="/listings/new">
          List your home
        </a>
        
        <!-- Profile Dropdown -->
        <div class="relative">
          <button id="user-menu-button" class="flex items-center gap-2 border border-gray-300 rounded-full p-2 hover:shadow-md transition-shadow duration-200 bg-white">
            <i class="fa-solid fa-bars text-gray-500 px-1 text-sm"></i>
            <div class="bg-gray-500 text-white rounded-full w-8 h-8 flex items-center justify-center">
              <i class="fa-solid fa-user text-sm"></i>
            </div>
          </button>
          
          <!-- Dropdown menu -->
          <div id="user-menu" class="hidden absolute right-0 mt-2 w-48 bg-white rounded-xl shadow-lg border border-gray-100 opacity-100 transition-all duration-200 overflow-hidden z-50">
            <% if(!currUser) { %>
              <a href="/signup" class="block px-4 py-3 text-sm text-gray-700 font-semibold hover:bg-gray-50 no-underline">Sign up</a>
              <a href="/login" class="block px-4 py-3 text-sm text-gray-700 hover:bg-gray-50 no-underline border-b border-gray-100">Log in</a>
              <a href="/listings/new" class="block px-4 py-3 text-sm text-gray-700 hover:bg-gray-50 no-underline sm:hidden">List your home</a>
            <% } else { %>
              <div class="px-4 py-3 border-b border-gray-100">
                <p class="text-sm text-gray-500">Welcome, <span class="font-semibold text-gray-800"><%= currUser.username || 'User' %></span>!</p>
              </div>
              <a href="/listings/new" class="block px-4 py-3 text-sm text-gray-700 font-semibold hover:bg-gray-50 no-underline">List your home</a>
              <a href="/logout" class="block px-4 py-3 text-sm text-rose-600 hover:bg-rose-50 font-semibold no-underline transition-colors mt-1">Log out</a>
            <% } %>
          </div>
        </div>
      </div>

    </div>
  </div>
  
  <script>
    const userMenuBtn = document.getElementById('user-menu-button');
    const userMenu = document.getElementById('user-menu');
    
    if(userMenuBtn && userMenu) {
      userMenuBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        userMenu.classList.toggle('hidden');
      });
      
      document.addEventListener('click', (e) => {
        if (!userMenu.contains(e.target) && !userMenuBtn.contains(e.target)) {
          userMenu.classList.add('hidden');
        }
      });
    }
  </script>
  
  <!-- Mobile Search Bar -->
  <% if (showSearchBar) { %>
    <div class="md:hidden px-4 pb-4">
      <form action="/listings" method="GET" class="flex items-center border border-gray-300 rounded-full shadow-sm pl-4 py-1.5 focus-within:ring-2 focus-within:ring-indigo-500">
        <input 
          type="text" 
          name="q"
          placeholder="Where to?" 
          class="flex-grow bg-transparent border-none text-sm outline-none px-2 w-full text-gray-700" 
        />
        <button type="submit" class="bg-gradient-to-r from-blue-600 to-purple-600 text-white rounded-full p-2.5 ml-2 w-10 h-10 flex items-center justify-center me-1">
          <i class="fa fa-search text-sm"></i>
        </button>
      </form>
    </div>
  <% } %>
</nav>
