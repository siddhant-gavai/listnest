<% layout('/layouts/boilerplate') -%>

<<!-- Categories / Filters Scrollable Row -->
<div class="sticky top-20 z-40 bg-white border-b border-gray-100 flex items-center justify-between px-4 sm:px-6 lg:px-8 py-4 shadow-sm mb-6 pb-2">
  <div id="filters" class="flex gap-6 overflow-x-auto no-scrollbar items-center max-w-[80%] hide-scrollbar">
    <% 
      const categories = [
        { name: "Farms", icon: "fa-tractor" },
        { name: "Rooms", icon: "fa-bed" },
        { name: "Amazing views", icon: "fa-image" },
        { name: "Iconic cities", icon: "fa-city" },
        { name: "Mountains", icon: "fa-mountain" },
        { name: "Surfing", icon: "fa-water" },
        { name: "Amazing pools", icon: "fa-swimming-pool" },
        { name: "Beach", icon: "fa-umbrella-beach" },
        { name: "Cabins", icon: "fa-home" },
        { name: "OMG!", icon: "fa-bolt" },
        { name: "Lakefront", icon: "fa-water" }
      ];
    %>
    <% for(let cat of categories) { %>
      <a href="/listings?category=<%= cat.name %>" class="no-underline flex flex-col items-center gap-2 cursor-pointer group min-w-[64px] border-b-2 <%= (typeof categoryFilter !== 'undefined' && categoryFilter === cat.name) ? 'border-black opacity-100' : 'border-transparent opacity-70 hover:opacity-100 hover:border-gray-300' %> pb-2 transition-all">
        <i class="fas <%= cat.icon %> text-gray-800 text-xl group-hover:text-black"></i>
        <span class="text-xs font-semibold text-gray-800 group-hover:text-black whitespace-nowrap"><%= cat.name %></span>
      </a>
    <% } %>
  </div>

  <!-- Tax Toggle -->
  <div class="hidden sm:flex items-center gap-3 border border-gray-300 rounded-xl px-4 py-3 hover:border-black transition-colors cursor-pointer bg-white" id="tax-toggle-btn">
    <span class="text-xs font-semibold text-gray-800 whitespace-nowrap">Display total after taxes</span>
    <div class="relative inline-block w-10 mr-2 align-middle select-none transition duration-200 ease-in">
      <input type="checkbox" id="switchCheckDefault" class="toggle-checkbox absolute block w-5 h-5 rounded-full bg-white border-4 appearance-none cursor-pointer transition-transform duration-300"/>
      <label for="switchCheckDefault" class="toggle-label block overflow-hidden h-5 rounded-full bg-gray-300 cursor-pointer"></label>
    </div>
  </div>
</div>

<style>
  /* Toggle Switch Custom CSS to complement Tailwind */
  .toggle-checkbox:checked {
    right: 0;
    border-color: #222;
  }
  .toggle-checkbox:checked + .toggle-label {
    background-color: #222;
  }
  .toggle-checkbox {
    right: 1.25rem;
    border-color: #d1d5db;
    z-index: 1;
  }
  /* Hide scrollbar for Chrome, Safari and Opera */
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
  /* Hide scrollbar for IE, Edge and Firefox */
  .hide-scrollbar {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
  
  .heart-btn.liked path {
    fill: #ff385c;
    stroke: #ff385c;
  }
</style>

<!-- Main Listings Grid -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4 mb-16">
  
  <% if(allListings && allListings.length > 0) { %>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
      <% for(let listing of allListings ){ %>
      <div class="listing-link group no-underline text-black block cursor-pointer" onclick="window.location.href='/listings/<%=listing._id%>'">
        <div class="relative aspect-square w-full overflow-hidden rounded-xl bg-gray-200 mb-3">
          <img
            src="<%= listing.image.url%>"
            alt="listing_image"
            class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
            loading="lazy"
          />
          <!-- Heart Icon Overlay (Persistence Wishlist) -->
          <div class="absolute top-3 right-3 text-white transition-transform z-10 hover:scale-110" onclick="event.stopPropagation(); toggleLike('<%= listing._id %>', this)">
            <% 
              let liked = false;
              if(currUser && currUser.wishlist) {
                liked = currUser.wishlist.some(wishId => wishId.toString() === listing._id.toString());
              }
            %>
            <svg class="heart-btn <%= liked ? 'liked' : '' %>" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" aria-hidden="true" role="presentation" focusable="false" style="display: block; fill: rgba(0, 0, 0, 0.5); height: 24px; width: 24px; stroke: white; stroke-width: 2; overflow: visible;">
              <path d="M16 28c7-4.73 14-10 14-17a6.98 6.98 0 0 0-7-7c-1.8 0-3.58.68-4.95 2.05L16 8.1l-2.05-2.05a6.98 6.98 0 0 0-9.9 0A6.98 6.98 0 0 0 2 11c0 7 7 12.27 14 17z"></path>
            </svg>
          </div>
        </div>
        
        <div class="flex justify-between items-start">
          <div class="flex-1">
            <h3 class="text-sm font-semibold text-gray-900 truncate pr-2"><%= listing.location %>, <%= listing.country %></h3>
            <p class="text-sm text-gray-500 mt-0.5 truncate pr-2"><%= listing.title %></p>
            <div class="mt-1 flex items-baseline gap-1">
              <span class="text-sm font-semibold text-gray-900 listing-price" data-base-price="<%= listing.price %>">&#8377; <%= listing.price.toLocaleString("en-IN") %></span>
              <span class="text-sm text-gray-900">night</span>
              <span class="tax-info hidden text-xs text-gray-500 ml-1">(incl. 18% GST)</span>
            </div>
          </div>
          <!-- Dynamic Rating (Randomized but consistent for session) -->
          <div class="flex items-center gap-1 text-sm text-gray-900">
            <i class="fa-solid fa-star text-xs"></i>
            <% let rating = (Math.random() * (5.0 - 4.5) + 4.5).toFixed(1); %>
            <span><%= rating %></span>
          </div>
        </div>
      </div>
      <% } %>
    </div>
  <% } else { %>
    <!-- Empty State -->
    <div class="flex flex-col items-center justify-center py-20 text-center">
      <div class="bg-gray-100 p-6 rounded-full mb-4">
        <i class="fa-solid fa-magnifying-glass text-4xl text-gray-400"></i>
      </div>
      <h2 class="text-2xl font-bold text-gray-900 mb-2">No exact matches</h2>
      <p class="text-gray-500 max-w-md">Try changing or removing some of your filters or adjusting your search area.</p>
      <a href="/listings" class="mt-6 px-6 py-3 border border-black rounded-lg font-semibold hover:bg-gray-50 transition-colors no-underline text-black">Remove all filters</a>
    </div>
  <% } %>

</div>

<script>
  // Setup tax toggle listener
  const taxSwitch = document.getElementById("switchCheckDefault");
  const taxToggleBtn = document.getElementById("tax-toggle-btn");
  
  if(taxToggleBtn) {
    taxToggleBtn.addEventListener("click", (e) => {
        if(e.target !== taxSwitch) {
            taxSwitch.click();
        }
    });
  }

  if(taxSwitch) {
    taxSwitch.addEventListener("change", (e) => {
      let prices = document.querySelectorAll(".listing-price");
      let taxInfos = document.querySelectorAll(".tax-info");
      
      prices.forEach((priceSpan, idx) => {
          let basePrice = parseFloat(priceSpan.getAttribute("data-base-price"));
          if(e.target.checked) {
              let totalWithTax = basePrice * 1.18;
              priceSpan.innerText = "₹ " + totalWithTax.toLocaleString("en-IN");
              taxInfos[idx].classList.remove('hidden');
          } else {
              priceSpan.innerText = "₹ " + basePrice.toLocaleString("en-IN");
              taxInfos[idx].classList.add('hidden');
          }
      });
    });
  }

  // Heart / Like Logic (Persistence)
  async function toggleLike(id, btn) {
      if(!'<%= currUser %>') {
          window.location.href = '/login';
          return;
      }

      const svg = btn.querySelector('svg');
      
      try {
          const response = await fetch(`/wishlist/${id}`, { method: 'POST' });
          const result = await response.json();
          
          if (result.success) {
              if (result.liked) {
                  svg.classList.add('liked');
              } else {
                  svg.classList.remove('liked');
              }
          }
      } catch (error) {
          console.error("Wishlist Error:", error);
      }
  }
</script>
