<% layout('/layouts/boilerplate') -%>

<!-- Categories / Filters Scrollable Row -->
<div class="sticky top-20 z-40 bg-white border-b border-gray-100 flex items-center justify-between px-4 sm:px-6 lg:px-8 py-4 shadow-sm mb-6 pb-2">
  <div id="filters" class="flex gap-6 overflow-x-auto no-scrollbar items-center max-w-[80%] hide-scrollbar">
    <!-- Filter items (you can dynamically generate these later) -->
    <div class="flex flex-col items-center gap-2 cursor-pointer group min-w-[64px] border-b-2 border-black pb-2 opacity-100 transition-opacity">
      <i class="fas fa-tractor text-gray-800 text-xl group-hover:text-black"></i>
      <span class="text-xs font-semibold text-gray-800 group-hover:text-black">Farms</span>
    </div>
    <div class="flex flex-col items-center gap-2 cursor-pointer group min-w-[64px] border-b-2 border-transparent hover:border-gray-300 pb-2 opacity-70 hover:opacity-100 transition-all">
      <i class="fas fa-bed text-gray-600 text-xl group-hover:text-black"></i>
      <span class="text-xs font-semibold text-gray-600 group-hover:text-black">Rooms</span>
    </div>
    <div class="flex flex-col items-center gap-2 cursor-pointer group min-w-[64px] border-b-2 border-transparent hover:border-gray-300 pb-2 opacity-70 hover:opacity-100 transition-all">
      <i class="fas fa-image text-gray-600 text-xl group-hover:text-black"></i>
      <span class="text-xs font-semibold text-gray-600 group-hover:text-black">Views</span>
    </div>
    <div class="flex flex-col items-center gap-2 cursor-pointer group min-w-[64px] border-b-2 border-transparent hover:border-gray-300 pb-2 opacity-70 hover:opacity-100 transition-all">
      <i class="fas fa-city text-gray-600 text-xl group-hover:text-black"></i>
      <span class="text-xs font-semibold text-gray-600 group-hover:text-black">Cities</span>
    </div>
    <div class="flex flex-col items-center gap-2 cursor-pointer group min-w-[64px] border-b-2 border-transparent hover:border-gray-300 pb-2 opacity-70 hover:opacity-100 transition-all">
      <i class="fas fa-mountain text-gray-600 text-xl group-hover:text-black"></i>
      <span class="text-xs font-semibold text-gray-600 group-hover:text-black">Mountains</span>
    </div>
    <div class="flex flex-col items-center gap-2 cursor-pointer group min-w-[64px] border-b-2 border-transparent hover:border-gray-300 pb-2 opacity-70 hover:opacity-100 transition-all">
      <i class="fas fa-water text-gray-600 text-xl group-hover:text-black"></i>
      <span class="text-xs font-semibold text-gray-600 group-hover:text-black">Surfing</span>
    </div>
    <div class="flex flex-col items-center gap-2 cursor-pointer group min-w-[64px] border-b-2 border-transparent hover:border-gray-300 pb-2 opacity-70 hover:opacity-100 transition-all">
      <i class="fas fa-swimming-pool text-gray-600 text-xl group-hover:text-black"></i>
      <span class="text-xs font-semibold text-gray-600 group-hover:text-black">Pools</span>
    </div>
    <div class="flex flex-col items-center gap-2 cursor-pointer group min-w-[64px] border-b-2 border-transparent hover:border-gray-300 pb-2 opacity-70 hover:opacity-100 transition-all">
      <i class="fas fa-umbrella-beach text-gray-600 text-xl group-hover:text-black"></i>
      <span class="text-xs font-semibold text-gray-600 group-hover:text-black">Beach</span>
    </div>
    <div class="flex flex-col items-center gap-2 cursor-pointer group min-w-[64px] border-b-2 border-transparent hover:border-gray-300 pb-2 opacity-70 hover:opacity-100 transition-all">
      <i class="fas fa-home text-gray-600 text-xl group-hover:text-black"></i>
      <span class="text-xs font-semibold text-gray-600 group-hover:text-black">Cabins</span>
    </div>
  </div>

  <!-- Tax Toggle -->
  <div class="hidden sm:flex items-center gap-3 border border-gray-300 rounded-xl px-4 py-3 hover:border-black transition-colors cursor-pointer bg-white" onclick="document.getElementById('switchCheckDefault').click()">
    <span class="text-xs font-semibold text-gray-800 whitespace-nowrap">Display total before taxes</span>
    <div class="relative inline-block w-10 mr-2 align-middle select-none transition duration-200 ease-in">
      <input type="checkbox" id="switchCheckDefault" class="toggle-checkbox absolute block w-5 h-5 rounded-full bg-white border-4 appearance-none cursor-pointer transition-transform duration-300"/>
      <label for="switchCheckDefault" class="toggle-label block overflow-hidden h-5 rounded-full bg-gray-300 cursor-pointer"></label>
    </div>
  </div>
</div>

<style>
  /* Toggle Switch Custom CSS to complement Tailwind */
  .toggle-checkbox:checked {
    right: 0;
    border-color: #222;
  }
  .toggle-checkbox:checked + .toggle-label {
    background-color: #222;
  }
  .toggle-checkbox {
    right: 1.25rem;
    border-color: #d1d5db;
    z-index: 1;
  }
  /* Hide scrollbar for Chrome, Safari and Opera */
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
  /* Hide scrollbar for IE, Edge and Firefox */
  .hide-scrollbar {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
</style>

<!-- Main Listings Grid -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4 mb-16">
  
  <% if(allListings && allListings.length > 0) { %>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
      <% for(let listing of allListings ){ %>
      <a href="/listings/<%=listing._id%>" class="group no-underline text-black block">
        <div class="relative aspect-square w-full overflow-hidden rounded-xl bg-gray-200 mb-3">
          <img
            src="<%= listing.image.url%>"
            alt="listing_image"
            class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
            loading="lazy"
          />
          <!-- Heart Icon Overlay (UI only) -->
          <div class="absolute top-3 right-3 text-white opacity-80 hover:opacity-100 hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" aria-hidden="true" role="presentation" focusable="false" style="display: block; fill: rgba(0, 0, 0, 0.5); height: 24px; width: 24px; stroke: white; stroke-width: 2; overflow: visible;">
              <path d="M16 28c7-4.73 14-10 14-17a6.98 6.98 0 0 0-7-7c-1.8 0-3.58.68-4.95 2.05L16 8.1l-2.05-2.05a6.98 6.98 0 0 0-9.9 0A6.98 6.98 0 0 0 2 11c0 7 7 12.27 14 17z"></path>
            </svg>
          </div>
        </div>
        
        <div class="flex justify-between items-start">
          <div class="flex-1">
            <h3 class="text-sm font-semibold text-gray-900 truncate pr-2"><%= listing.location %>, <%= listing.country %></h3>
            <p class="text-sm text-gray-500 mt-0.5 truncate pr-2"><%= listing.title %></p>
            <div class="mt-1 flex items-baseline gap-1">
              <span class="text-sm font-semibold text-gray-900">&#8377; <%= listing.price.toLocaleString("en-IN") %></span>
              <span class="text-sm text-gray-900">night</span>
              <span class="taxPrice hidden text-sm text-gray-500 underline ml-1">+18% GST</span>
            </div>
          </div>
          <!-- Dummy Rating -->
          <div class="flex items-center gap-1 text-sm text-gray-900">
            <i class="fa-solid fa-star text-xs"></i>
            <span><%= (Math.random() * (5.0 - 4.2) + 4.2).toFixed(2) %></span>
          </div>
        </div>
      </a>
      <% } %>
    </div>
  <% } else { %>
    <!-- Empty State -->
    <div class="flex flex-col items-center justify-center py-20 text-center">
      <div class="bg-gray-100 p-6 rounded-full mb-4">
        <i class="fa-solid fa-magnifying-glass text-4xl text-gray-400"></i>
      </div>
      <h2 class="text-2xl font-bold text-gray-900 mb-2">No exact matches</h2>
      <p class="text-gray-500 max-w-md">Try changing or removing some of your filters or adjusting your search area.</p>
      <a href="/listings" class="mt-6 px-6 py-3 border border-black rounded-lg font-semibold hover:bg-gray-50 transition-colors no-underline text-black">Remove all filters</a>
    </div>
  <% } %>

</div>

<script>
  // Setup tax toggle listener
  const taxSwitch = document.getElementById("switchCheckDefault");
  if(taxSwitch) {
    taxSwitch.addEventListener("change", (e) => {
      let taxInfo = document.querySelectorAll(".taxPrice");
      if(e.target.checked) {
        taxInfo.forEach(info => { info.style.display = "inline"; info.classList.remove('hidden'); });
      } else {
        taxInfo.forEach(info => { info.style.display = "none"; info.classList.add('hidden'); });
      }
    });
  }
</script>
