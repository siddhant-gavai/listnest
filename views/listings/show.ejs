<% layout('/layouts/boilerplate') %>

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 mt-8 mb-16">
  <!-- Header -->
  <div class="mb-6">
    <h1 class="text-3xl font-semibold tracking-tight text-gray-900 mb-2"><%= listing.title %></h1>
    <div class="flex items-center text-sm text-gray-700 font-medium pb-4 border-bottom">
      <i class="fa-solid fa-star mr-1"></i>
      <span><%= (Math.random() * (5.0 - 4.2) + 4.2).toFixed(2) %> &middot; </span>
      <span class="underline mx-2"><%= listing.reviews.length %> reviews</span>
      <span>&middot;</span>
      <span class="underline ml-2"><%= listing.location %>, <%= listing.country %></span>
    </div>
  </div>

  <!-- Hero Image -->
  <div class="w-full h-[50vh] rounded-2xl overflow-hidden mb-8 shadow-sm">
    <img
      src="<%= listing.image.url %>"
      alt="Listing Image"
      class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"
    />
  </div>

  <!-- Content Grid -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
    <!-- Main Info -->
    <div class="lg:col-span-2">
      <div class="flex justify-between items-center pb-6 border-b border-gray-200">
        <div>
          <h2 class="text-xl font-semibold mb-1">
            Hosted by <%= listing.owner ? listing.owner.username : 'Unknown' %>
          </h2>
          <p class="text-gray-500">2 guests &middot; 1 bedroom &middot; 1 bed &middot; 1 bath</p>
        </div>
        <div class="w-14 h-14 bg-indigo-100 rounded-full flex items-center justify-center text-indigo-500 text-2xl">
          <i class="fa-solid fa-user"></i>
        </div>
      </div>
      
      <div class="py-6 border-b border-gray-200">
        <div class="flex items-start gap-4 mb-4">
          <i class="fa-solid fa-medal text-2xl text-gray-700"></i>
          <div>
            <h3 class="font-semibold text-gray-900">Superhost</h3>
            <p class="text-gray-500 text-sm">Superhosts are experienced, highly rated hosts who are committed to providing great stays.</p>
          </div>
        </div>
        <div class="flex items-start gap-4 mb-4">
          <i class="fa-solid fa-location-dot text-2xl text-gray-700"></i>
          <div>
            <h3 class="font-semibold text-gray-900">Great location</h3>
            <p class="text-gray-500 text-sm">100% of recent guests gave the location a 5-star rating.</p>
          </div>
        </div>
      </div>

      <div class="py-6 border-b border-gray-200">
        <p class="text-gray-700 leading-relaxed"><%= listing.description %></p>
      </div>
    </div>

    <!-- Pricing Card -->
    <div class="lg:col-span-1">
      <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-xl sticky top-28">
        <div class="flex justify-between items-baseline mb-4">
          <div>
            <span class="text-2xl font-bold text-gray-900">&#8377; <%= listing.price.toLocaleString("en-IN") %></span>
            <span class="text-gray-500"> night</span>
          </div>
          <div class="text-sm font-semibold">
            <i class="fa-solid fa-star text-xs"></i> 4.9 &middot; <span class="text-gray-500 underline"><%= listing.reviews.length %> reviews</span>
          </div>
        </div>
        
        <div class="mt-4">
          <button class="w-full bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 transition-all duration-300 transform hover:scale-[1.02] text-white font-semibold py-3 rounded-lg shadow-md">
            Reserve
          </button>
        </div>
        
        <div class="text-center text-gray-500 text-sm mt-4">You won't be charged yet</div>

        <% if (currUser && listing.owner && currUser._id.equals(listing.owner._id)) { %>
        <!-- Owner Actions -->
        <hr class="my-6 border-gray-200">
        <div class="space-y-3">
          <p class="text-sm font-semibold text-gray-700 mb-2">Host Settings</p>
          <a href="/listings/<%= listing._id %>/edit" class="block w-full text-center bg-gray-100 hover:bg-gray-200 text-gray-900 font-semibold py-2.5 rounded-lg transition-colors no-underline">
            Edit Listing
          </a>
          <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="w-full m-0">
            <button class="w-full bg-rose-50 hover:bg-rose-100 text-rose-600 font-semibold py-2.5 rounded-lg transition-colors border border-rose-100">
              Delete Listing
            </button>
          </form>
        </div>
        <% } %>
      </div>
    </div>
  </div>

  <hr class="my-10 border-gray-200" />

  <!-- Reviews Section -->
  <div class="mb-10">
    <div class="flex items-center text-xl font-semibold tracking-tight text-gray-900 mb-6">
      <i class="fa-solid fa-star mr-2 text-lg"></i>
      <span>4.9 &middot; <%= listing.reviews.length %> reviews</span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8 mb-8">
      <% for (let review of listing.reviews) { %>
      <div>
        <div class="flex items-center gap-3 mb-3">
          <div class="w-10 h-10 bg-gray-200 rounded-full flex items-center justify-center">
             <i class="fa-solid fa-user text-gray-500"></i>
          </div>
          <div>
            <h4 class="font-semibold text-gray-900 text-sm"><%= review.author ? review.author.username : 'Unknown' %></h4>
            <p class="text-gray-500 text-xs">Recently</p>
          </div>
        </div>
        <div>
          <p class="starability-result card-text scale-[0.6] origin-left" data-rating="<%= review.rating %>"></p>
        </div>
        <p class="text-gray-700 text-sm mt-2 leading-relaxed"><%= review.comment %></p>
        
        <% if (currUser && review.author && currUser._id.equals(review.author._id)) { %>
        <form class="mt-3" method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
          <button class="text-sm text-gray-500 underline hover:text-black transition-colors font-medium">Delete review</button>
        </form>
        <% } %>
      </div>
      <% } %>
    </div>
  </div>

  <% if(currUser) { %>
  <!-- Add Review form -->
  <div class="max-w-2xl bg-gray-50 p-6 rounded-2xl border border-gray-100 mt-8">
    <h4 class="text-lg font-semibold mb-4 text-gray-900">Leave a Review</h4>
    <form action="/listings/<%= listing._id %>/reviews" method="POST" class="needs-validation" novalidate>
      <div class="mb-4">
        <fieldset class="starability-growRotate">
          <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating."/>
          <input type="radio" id="first-rate1" name="review[rating]" value="1" />
          <label for="first-rate1" title="Terrible">1 star</label>
          <input type="radio" id="first-rate2" name="review[rating]" value="2" />
          <label for="first-rate2" title="Not good">2 stars</label>
          <input type="radio" id="first-rate3" name="review[rating]" value="3" />
          <label for="first-rate3" title="Average">3 stars</label>
          <input type="radio" id="first-rate4" name="review[rating]" value="4" />
          <label for="first-rate4" title="Very good">4 stars</label>
          <input type="radio" id="first-rate5" name="review[rating]" value="5" />
          <label for="first-rate5" title="Amazing">5 stars</label>
        </fieldset>
      </div>

      <div class="mb-4">
        <label for="comment" class="block text-sm font-medium text-gray-700 mb-2">Comment</label>
        <textarea
          name="review[comment]"
          id="comment"
          rows="4"
          placeholder="Share your experience..."
          class="w-full border border-gray-300 rounded-lg p-3 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none"
          required
        ></textarea>
        <div class="invalid-feedback text-sm text-rose-500 mt-1">Please enter a comment before submitting.</div>
      </div>

      <button class="bg-gray-900 hover:bg-gray-800 text-white font-semibold py-2 px-6 rounded-lg transition-colors">
        Submit Review
      </button>
    </form>
  </div>
  <% } %>

</div>
