<% layout('/layouts/boilerplate') %>

<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 mt-12 mb-20 bg-white shadow-xl rounded-2xl border border-gray-100 p-8">
  <div class="mb-10 text-center">
    <h3 class="text-3xl font-bold tracking-tight text-gray-900">List your home</h3>
    <p class="text-gray-500 mt-2">Fill in the details to start hosting your space on Listnest.</p>
  </div>

  <!-- 🧠 Form starts here -->
  <form
    method="POST"
    action="/listings"
    novalidate
    class="needs-validation space-y-6"
    enctype="multipart/form-data"
    onsubmit="return handleSubmit(this)"
  >
    <!-- 🏷️ Title -->
    <div>
      <label for="title" class="block text-sm font-semibold text-gray-700 mb-1">Title</label>
      <input
        name="listing[title]"
        id="title"
        placeholder="Add a catchy title"
        type="text"
        class="form-control w-full border border-gray-300 rounded-xl px-4 py-3 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none text-gray-900 transition-shadow"
        required
      />
      <div class="valid-feedback text-sm text-green-600 mt-1">Title looks good</div>
    </div>

    <!-- 📝 Description -->
    <div>
      <label for="description" class="block text-sm font-semibold text-gray-700 mb-1">Description</label>
      <textarea
        name="listing[description]"
        id="description"
        rows="4"
        placeholder="Describe what makes your space special..."
        class="form-control w-full border border-gray-300 rounded-xl px-4 py-3 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none text-gray-900 transition-shadow resize-none"
        required
      ></textarea>
      <div class="valid-feedback text-sm text-green-600 mt-1">Description looks good</div>
      <div class="invalid-feedback text-sm text-rose-500 mt-1">Please enter a short description</div>
    </div>

    <!-- 🖼️ Image Upload -->
    <div>
      <label for="image" class="block text-sm font-semibold text-gray-700 mb-1">Upload Cover Image</label>
      <div class="relative">
        <input
          name="listing[image]"
          id="image"
          type="file"
          class="form-control w-full border border-gray-300 bg-gray-50 rounded-xl px-4 py-3 text-gray-700 focus:outline-none file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-600 hover:file:bg-indigo-100 transition-all"
          accept="image/*"
          onchange="validateImageSize(this)"
          required
        />
        <div class="invalid-feedback text-sm text-rose-500 mt-1">Please upload an image</div>
      </div>
      <p class="text-xs text-gray-500 mt-2">Maximum file size: 4MB (JPEG, PNG only)</p>
    </div>

    <!-- 💰 Price + 🌍 Country -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="md:col-span-1">
        <label for="price" class="block text-sm font-semibold text-gray-700 mb-1">Price per night</label>
        <div class="relative">
          <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-gray-500 font-medium">&#8377;</span>
          <input
            name="listing[price]"
            id="price"
            placeholder="1200"
            type="number"
            class="form-control w-full border border-gray-300 rounded-xl pl-9 pr-4 py-3 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none text-gray-900"
            required
          />
        </div>
        <div class="invalid-feedback text-sm text-rose-500 mt-1">Please enter a valid price</div>
      </div>

      <div class="md:col-span-2">
        <label for="country" class="block text-sm font-semibold text-gray-700 mb-1">Country</label>
        <input
          name="listing[country]"
          id="country"
          placeholder="Ex: India"
          type="text"
          class="form-control w-full border border-gray-300 rounded-xl px-4 py-3 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none text-gray-900"
          required
        />
        <div class="invalid-feedback text-sm text-rose-500 mt-1">Please enter the country</div>
      </div>
    </div>

    <!-- 📍 Location -->
    <div>
      <label for="location" class="block text-sm font-semibold text-gray-700 mb-1">City / Location</label>
      <input
        name="listing[location]"
        id="location"
        placeholder="Ex: Mumbai, Maharashtra"
        type="text"
        class="form-control w-full border border-gray-300 rounded-xl px-4 py-3 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none text-gray-900"
        required
      />
      <div class="invalid-feedback text-sm text-rose-500 mt-1">Please enter the location</div>
    </div>

    <!-- ✅ Submit Button -->
    <div class="pt-4">
      <button type="submit" class="w-full bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 text-white font-bold py-3.5 px-6 rounded-xl shadow-md transition-all duration-300 transform hover:scale-[1.02] flex justify-center items-center gap-2">
        <span>Publish Listing</span>
        <i class="fa-solid fa-arrow-right text-sm"></i>
      </button>
    </div>
  </form>

  <!-- ⏳ Loader Section (Hidden by default) -->
  <div id="loader" style="display: none" class="text-center py-10">
    <i class="fa-solid fa-circle-notch fa-spin text-4xl text-indigo-500 mb-4"></i>
    <p class="text-gray-600 font-medium">Please wait, creating your listing...</p>
  </div>
</div>

<!-- 🔁 Script: Loader + File Size Validation -->
<script>
  function validateImageSize(input) {
    const file = input.files[0];
    if (file && file.size > 4 * 1024 * 1024) {
      alert("Image must be smaller than 4MB.");
      input.value = ""; // Reset file input
    }
  }

  function handleSubmit(form) {
    const fileInput = form.querySelector('input[type="file"]');
    if (fileInput && fileInput.files[0]) {
      const file = fileInput.files[0];
      if (file.size > 4 * 1024 * 1024) {
        alert("Image must be smaller than 4MB.");
        return false; // Block form submission
      }
    }

    form.style.display = "none"; // Hide form
    document.getElementById("loader").style.display = "block"; // Show loader
    return true; // Allow submission
  }
</script>
