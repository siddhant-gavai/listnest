<% layout('/layouts/boilerplate') %>

<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 mt-12 mb-20 bg-white shadow-xl rounded-2xl border border-gray-100 p-8">
  <div class="mb-10 text-center">
    <h3 class="text-3xl font-bold tracking-tight text-gray-900">Edit your Listing</h3>
    <p class="text-gray-500 mt-2">Update the details of your space to keep it fresh and attractive.</p>
  </div>

  <form
    method="POST"
    action="/listings/<%= listing._id %>?_method=PUT"
    enctype="multipart/form-data"
    novalidate
    class="needs-validation space-y-6"
  >
    <!-- 🏷️ Title -->
    <div>
      <label for="title" class="block text-sm font-semibold text-gray-700 mb-1">Title</label>
      <input
        name="listing[title]"
        id="title"
        value="<%= listing.title %>"
        type="text"
        class="form-control w-full border border-gray-300 rounded-xl px-4 py-3 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none text-gray-900 transition-shadow"
        required
      />
    </div>

    <!-- 📝 Description -->
    <div>
      <label for="description" class="block text-sm font-semibold text-gray-700 mb-1">Description</label>
      <textarea 
        name="listing[description]" 
        id="description"
        rows="5"
        class="form-control w-full border border-gray-300 rounded-xl px-4 py-3 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none text-gray-900 transition-shadow resize-none" 
        required
      ><%= listing.description %></textarea>
    </div>

    <!-- Current Image Preview -->
    <div>
      <label class="block text-sm font-semibold text-gray-700 mb-2">Current Cover Image</label>
      <% const lowResUrl = listing.image && listing.image.url ? listing.image.url.replace('/upload/', '/upload/w_400,q_50/') : ''; %>
      <% if (lowResUrl) { %>
      <div class="relative w-full h-48 rounded-xl overflow-hidden border border-gray-200">
        <img
          src="<%= lowResUrl %>"
          alt="Current image"
          class="w-full h-full object-cover"
        />
      </div>
      <% } else { %>
        <p class="text-sm text-gray-500 italic">No image available.</p>
      <% } %>
    </div>

    <!-- 🖼️ New Image Upload -->
    <div>
      <label for="image" class="block text-sm font-semibold text-gray-700 mb-1">Upload New Image (Optional)</label>
      <input
        name="listing[image]"
        id="image"
        type="file"
        class="form-control w-full border border-gray-300 bg-gray-50 rounded-xl px-4 py-3 text-gray-700 focus:outline-none file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-600 hover:file:bg-indigo-100 transition-all"
        accept="image/*"
      />
      <p class="text-xs text-gray-500 mt-2">Leave blank if you don't want to change the current image.</p>
    </div>

    <!-- 💰 Price + 🌍 Country -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="md:col-span-1">
        <label for="price" class="block text-sm font-semibold text-gray-700 mb-1">Price per night</label>
        <div class="relative">
          <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-gray-500 font-medium">&#8377;</span>
          <input
            name="listing[price]"
            id="price"
            value="<%= listing.price %>"
            type="number"
            class="form-control w-full border border-gray-300 rounded-xl pl-9 pr-4 py-3 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none text-gray-900"
            required
          />
        </div>
      </div>

      <div class="md:col-span-2">
        <label for="country" class="block text-sm font-semibold text-gray-700 mb-1">Country</label>
        <input
          name="listing[country]"
          id="country"
          value="<%= listing.country %>"
          type="text"
          class="form-control w-full border border-gray-300 rounded-xl px-4 py-3 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none text-gray-900"
          required
        />
      </div>
    </div>

    <!-- 📍 Location -->
    <div>
      <label for="location" class="block text-sm font-semibold text-gray-700 mb-1">City / Location</label>
      <input
        name="listing[location]"
        id="location"
        value="<%= listing.location %>"
        type="text"
        class="form-control w-full border border-gray-300 rounded-xl px-4 py-3 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none text-gray-900"
        required
      />
    </div>

    <!-- ✅ Submit Button -->
    <div class="pt-4 flex items-center justify-between gap-4">
      <a href="/listings/<%= listing._id %>" class="text-sm font-semibold text-gray-500 hover:text-gray-800 transition-colors no-underline">Cancel</a>
      <button type="submit" class="w-1/2 bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 text-white font-bold py-3.5 px-6 rounded-xl shadow-md transition-all duration-300 transform hover:scale-[1.02] flex justify-center items-center gap-2">
        <span>Save Changes</span>
        <i class="fa-solid fa-check text-sm"></i>
      </button>
    </div>
  </form>
</div>
